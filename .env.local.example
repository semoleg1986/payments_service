POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payments_service

PAYMENTS_APP_NAME=payments_service
PAYMENTS_APP_HOST=0.0.0.0
PAYMENTS_APP_PORT=8004

PAYMENTS_DATABASE_URL=postgresql+psycopg://postgres:postgres@payments_postgres:5432/payments_service
PAYMENTS_USE_INMEMORY=0
PAYMENTS_AUTO_CREATE_SCHEMA=0

PAYMENTS_AUTH_ISSUER=auth_service
PAYMENTS_AUTH_AUDIENCE=platform_clients
PAYMENTS_AUTH_JWKS_URL=http://host.docker.internal:8000/.well-known/jwks.json
PAYMENTS_AUTH_JWKS_JSON=

PAYMENTS_SERVICE_TOKEN=dev-service-token
PAYMENTS_DEFAULT_CURRENCY=USD
PAYMENTS_INTEGRATIONS_USE_INMEMORY=1

PAYMENTS_COURSE_SERVICE_BASE_URL=http://host.docker.internal:8001
PAYMENTS_COURSE_SERVICE_TOKEN=dev-service-token
PAYMENTS_COURSE_SERVICE_TIMEOUT_SECONDS=2

PAYMENTS_USERS_SERVICE_BASE_URL=http://host.docker.internal:8002
PAYMENTS_USERS_SERVICE_TOKEN=dev-service-token
PAYMENTS_USERS_SERVICE_TIMEOUT_SECONDS=2
